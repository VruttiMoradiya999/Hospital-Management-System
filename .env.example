# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your MongoDB connection string (e.g., MongoDB Atlas or local instance)
MONGO_URI=mongodb://localhost:27017/hospital-management

# Authentication
# Replace with a long, random string for security
JWT_SECRET=your_jwt_secret_key_here

# Frontend Configuration (for Vite)
# This is used by the frontend to know where the backend API is located
VITE_API_URL=http://localhost:5000/api
